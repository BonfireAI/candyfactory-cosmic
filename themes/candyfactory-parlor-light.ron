// ════════════════════════════════════════════════════════════════
// CandyFactory · PARLOR (Light) · COSMIC Desktop theme
//
// Install:  ~/.config/cosmic/com.system76.CosmicTheme.Light/v1/CandyFactory-Parlor
// Or import via COSMIC Settings → Desktop → Appearance → Import.
//
// Cream background, ink ink, grape accent.
// See ../CLAUDE.md for the regeneration recipe.
// ════════════════════════════════════════════════════════════════
(
    palette: Light((
        name: "CandyFactory-Parlor-Grape",

        // —— Standard candy hues (darkened slightly for contrast on cream) ——
        blue:   (red: 0.184314, green: 0.521569, blue: 0.901961, alpha: 1.0),  // #2f85e6 deepened sky
        red:    (red: 0.886275, green: 0.180392, blue: 0.349020, alpha: 1.0),  // #e22e59 deepened cherry
        green:  (red: 0.239216, green: 0.639216, blue: 0.580392, alpha: 1.0),  // #3da394 deepened mint
        yellow: (red: 0.780392, green: 0.600000, blue: 0.000000, alpha: 1.0),  // #c79900 deepened butter

        // —— Surface grays (cream ramp) ——
        gray_1: (red: 1.000000, green: 0.972549, blue: 0.905882, alpha: 1.0),  // #fff8e7 cream
        gray_2: (red: 1.000000, green: 0.980392, blue: 0.941176, alpha: 1.0),  // #fffaf0 paper
        gray_3: (red: 0.968627, green: 0.941176, blue: 0.847059, alpha: 1.0),  // #f7f0d8 bg-soft

        // —— Neutral ramp (lightest → darkest) ——
        neutral_0:  (red: 1.000000, green: 1.000000, blue: 1.000000, alpha: 1.0),
        neutral_1:  (red: 1.000000, green: 0.980392, blue: 0.941176, alpha: 1.0),  // #fffaf0 paper
        neutral_2:  (red: 1.000000, green: 0.972549, blue: 0.905882, alpha: 1.0),  // #fff8e7 cream
        neutral_3:  (red: 0.968627, green: 0.941176, blue: 0.847059, alpha: 1.0),  // #f7f0d8
        neutral_4:  (red: 0.929412, green: 0.894118, blue: 0.784314, alpha: 1.0),  // #ede4c8
        neutral_5:  (red: 0.784314, green: 0.741176, blue: 0.627451, alpha: 1.0),  // #c8bda0
        neutral_6:  (red: 0.600000, green: 0.541176, blue: 0.458824, alpha: 1.0),  // #998a75
        neutral_7:  (red: 0.431373, green: 0.384314, blue: 0.325490, alpha: 1.0),  // #6e6253
        neutral_8:  (red: 0.290196, green: 0.247059, blue: 0.368627, alpha: 1.0),  // #4a3f5e ink-soft
        neutral_9:  (red: 0.176471, green: 0.145098, blue: 0.250980, alpha: 1.0),  // #2d2540
        neutral_10: (red: 0.101961, green: 0.086275, blue: 0.149020, alpha: 1.0),  // #1a1626 ink

        // —— Bright variants ——
        bright_green:  (red: 0.372549, green: 0.831373, blue: 0.768627, alpha: 1.0),
        bright_red:    (red: 1.000000, green: 0.231373, blue: 0.419608, alpha: 1.0),
        bright_orange: (red: 1.000000, green: 0.647059, blue: 0.301961, alpha: 1.0),

        // —— Extended (syntax-highlight grade) ——
        ext_warm_grey: (red: 0.431373, green: 0.384314, blue: 0.325490, alpha: 1.0),
        ext_orange:    (red: 0.835294, green: 0.486275, blue: 0.000000, alpha: 1.0),
        ext_yellow:    (red: 0.780392, green: 0.600000, blue: 0.000000, alpha: 1.0),
        ext_blue:      (red: 0.184314, green: 0.521569, blue: 0.901961, alpha: 1.0),
        ext_purple:    (red: 0.494118, green: 0.219608, blue: 0.870588, alpha: 1.0),  // deepened grape
        ext_pink:      (red: 0.886275, green: 0.262745, blue: 0.580392, alpha: 1.0),  // deepened pink
        ext_indigo:    (red: 0.337255, green: 0.247059, blue: 0.886275, alpha: 1.0),

        // —— Accent picker ——
        accent_blue:      (red: 0.184314, green: 0.521569, blue: 0.901961, alpha: 1.0),
        accent_red:       (red: 0.886275, green: 0.180392, blue: 0.349020, alpha: 1.0),
        accent_green:     (red: 0.239216, green: 0.639216, blue: 0.580392, alpha: 1.0),
        accent_warm_grey: (red: 0.431373, green: 0.384314, blue: 0.325490, alpha: 1.0),
        accent_orange:    (red: 0.835294, green: 0.486275, blue: 0.000000, alpha: 1.0),
        accent_yellow:    (red: 0.780392, green: 0.600000, blue: 0.000000, alpha: 1.0),
        accent_purple:    (red: 0.494118, green: 0.219608, blue: 0.870588, alpha: 1.0),  // grape ★ default
        accent_pink:      (red: 0.886275, green: 0.262745, blue: 0.580392, alpha: 1.0),
        accent_indigo:    (red: 0.337255, green: 0.247059, blue: 0.886275, alpha: 1.0),
    )),

    spacing: (
        space_none: 0,
        space_xxxs: 4,
        space_xxs:  8,
        space_xs:  12,
        space_s:   16,
        space_m:   24,
        space_l:   32,
        space_xl:  48,
        space_xxl: 64,
        space_xxxl: 128,
    ),

    corner_radii: (
        radius_0:  (0.0,  0.0,  0.0,  0.0),
        radius_xs: (4.0,  4.0,  4.0,  4.0),
        radius_s:  (8.0,  8.0,  8.0,  8.0),
        radius_m:  (12.0, 12.0, 12.0, 12.0),
        radius_l:  (18.0, 18.0, 18.0, 18.0),
        radius_xl: (24.0, 24.0, 24.0, 24.0),
    ),

    bg_color:               Some((red: 1.000000, green: 0.972549, blue: 0.905882, alpha: 1.0)),  // cream
    text_tint:              Some((red: 0.101961, green: 0.086275, blue: 0.149020)),              // ink
    accent:                 Some((red: 0.494118, green: 0.219608, blue: 0.870588)),              // grape
    success:                Some((red: 0.239216, green: 0.639216, blue: 0.580392)),              // mint
    warning:                Some((red: 0.780392, green: 0.600000, blue: 0.000000)),              // butter
    destructive:            Some((red: 0.886275, green: 0.180392, blue: 0.349020)),              // cherry
    window_hint:            Some((red: 0.886275, green: 0.262745, blue: 0.580392)),              // pink
    neutral_tint:           None,
    primary_container_bg:   None,
    secondary_container_bg: None,

    is_frosted:  false,
    gaps:        (4, 8),
    active_hint: 3,
)
