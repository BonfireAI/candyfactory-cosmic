// ════════════════════════════════════════════════════════════════
// CandyFactory · BONFIRE · cosmic-term color scheme
//
// Install: ~/.config/cosmic/com.system76.CosmicTerm/v1/color_schemes/CandyFactory-Bonfire.ron
// Or via cosmic-term → View → Color schemes → Import.
//
// Maps the 16-color ANSI palette to CandyFactory's candy hues
// on the "candied dark" terminal surface used by Bonfire CLI.
//
// Schema cross-checked 2026-05-20 against cosmic-term/src/config.rs
// (struct ColorScheme uses bare hex strings; `Some(...)` wrappers
// are rejected, and unknown fields are denied — `selection_*`
// fields do not exist in the struct).
// ════════════════════════════════════════════════════════════════
(
    name: "CandyFactory Bonfire",
    foreground: "#fff8e7",
    background: "#14101e",
    cursor: "#ffd84d",
    bright_foreground: "#fffaf0",
    dim_foreground: "#b4a8c2",
    normal: (
        black: "#1a1626",
        red: "#ff3b6b",
        green: "#5fd4c4",
        yellow: "#ffd84d",
        blue: "#5fb8ff",
        magenta: "#ff5fa2",
        cyan: "#84e3d5",
        white: "#d6cde0",
    ),
    bright: (
        black: "#4a3f5e",
        red: "#ff6b8f",
        green: "#84e3d5",
        yellow: "#ffe27a",
        blue: "#8acdff",
        magenta: "#a96bff",
        cyan: "#a4ecdf",
        white: "#fff8e7",
    ),
    dim: (
        black: "#0e0a16",
        red: "#cc2f55",
        green: "#4cb09e",
        yellow: "#cca835",
        blue: "#4c8fcc",
        magenta: "#cc4c80",
        cyan: "#6caa9e",
        white: "#8e80a3",
    ),
)
